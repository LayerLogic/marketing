---
import HeroLattice3D from "~/components/react/HeroLattice3D.tsx";
import HeroTicker from "~/components/react/HeroTicker.tsx";
import HeroVisual from "./HeroVisual.astro";
import ScrollReveal from "~/components/react/ScrollReveal.tsx";

const base = import.meta.env.BASE_URL;

// Curated backer strip. Logos reuse the grid assets; tiles without a logo
// file fall back to the wordmark (same pattern as the investor grid).
const heroBackers = [
  { name: "Chalmers Ventures", logo: "assets/partners/chalmers-ventures.png" },
  { name: "Scientifica VC", logo: "assets/partners/scientifica.svg" },
  { name: "EIT Food", logo: "assets/partners/eit-food.png" },
  { name: "X&Y Invest", logo: "assets/partners/xy-invest.png" },
  { name: "MassChallenge", logo: "assets/recognitions/masschallenge.png" },
  {
    name: "Yeos Ventures",
    logo: "assets/partners/yeos-ventures.png",
    logoClass: "logo-avatar",
  },
];
---

<section
  id="top"
  class="relative overflow-hidden border-b border-line min-h-svh"
>
  {/* Static SVG fallback — visible until the WebGL island hydrates. */}
  <div
    class="hero-svg-fallback absolute inset-0 pointer-events-none"
    style="z-index:0"
    aria-hidden="true"
  >
    <svg
      class="absolute inset-[-10%] w-[120%] h-[120%] opacity-[0.18] lattice-drift"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <pattern
          id="hex"
          x="0"
          y="0"
          width="86.6"
          height="150"
          patternUnits="userSpaceOnUse"
        >
          <g fill="none" stroke="#06B6A7" stroke-width="0.7">
            <polygon points="43.3,0 86.6,25 86.6,75 43.3,100 0,75 0,25"
            ></polygon>
            <polygon
              points="0,75 43.3,100 43.3,150 0,175 -43.3,150 -43.3,100"
            ></polygon>
            <polygon
              points="86.6,75 129.9,100 129.9,150 86.6,175 43.3,150 43.3,100"
            ></polygon>
          </g>
        </pattern>
        <radialGradient id="hexFade" cx="50%" cy="40%" r="60%">
          <stop offset="0%" stop-color="#000" stop-opacity="0"></stop>
          <stop offset="100%" stop-color="#000" stop-opacity="1"></stop>
        </radialGradient>
        <mask id="hexMask"
          ><rect
            width="100%"
            height="100%"
            fill="url(#hexFade)"
            style="filter:invert(1)"></rect></mask
        >
      </defs>
      <rect width="100%" height="100%" fill="url(#hex)" mask="url(#hexMask)"
      ></rect>
    </svg>
  </div>

  {/* WebGL graphene lattice — replaces the SVG once hydrated */}
  <HeroLattice3D client:idle />

  {/* Vignette dims the lattice in the reading area; sits above both
      background layers so text always has a calm field behind it. */}
  <div
    class="hero-vignette absolute inset-0 pointer-events-none"
    style="z-index:2"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative z-10 max-w-330 mx-auto w-full px-6 lg:px-10 pt-20 lg:pt-28 pb-20 lg:pb-28"
  >
    <div class="flex items-center justify-between mb-14 lg:mb-20">
      <div class="flex items-center gap-3 text-paper">
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full rounded-full bg-accent pulse-dot"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"
          ></span>
        </span>
        <span class="label">Live · Sensor reading</span>
        <HeroTicker client:idle />
      </div>
    </div>

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
      <ScrollReveal client:visible className="lg:col-span-7">
        <h1
          class="display text-[clamp(48px,8vw,128px)] font-medium max-w-[18ch] text-paper"
        >
          Pathogens,<br />
           detected in <span class="text-accent">minutes.</span><br />
          <span class="text-mute2">Not days.</span>
        </h1>
      </ScrollReveal>
      <ScrollReveal client:visible delay={200} className="lg:col-span-5">
        <HeroVisual />
      </ScrollReveal>
    </div>

    <div class="mt-12 lg:mt-16 grid lg:grid-cols-12 gap-10 items-end">
      <ScrollReveal client:visible delay={120} className="lg:col-span-6">
        <p
          class="text-[19px] lg:text-[22px] leading-[1.4] text-paper/80 max-w-[42ch]"
        >
          We build a portable sensor for food producers. Test for Listeria
          right where the food is made, and get clear results in minutes
          instead of waiting days for the lab.
        </p>
      </ScrollReveal>
      <ScrollReveal client:visible delay={220} className="lg:col-span-6">
        <div class="flex flex-col items-start lg:items-end gap-6">
          <div class="flex flex-wrap gap-3">
            <a href="#contact" class="lb-btn lb-btn--primary">
              <span class="lb-label">Request a demo</span>
              <span class="lb-chip">
                <svg width="14" height="14" viewBox="0 0 14 14"
                  ><path
                    d="M2 7h9M7 3l4 4-4 4"
                    stroke="currentColor"
                    stroke-width="1.5"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path></svg
                >
              </span>
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>

    <div class="mt-20 lg:mt-28 pt-8 border-t border-line">
      <div class="label mb-5">Backed &amp; supported by</div>
      <div
        class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-6 gap-x-8 items-center"
      >
        {
          heroBackers.map((b) => (
            <div class="flex items-center min-h-14">
              {b.logo && (
                <img
                  src={`${base}${b.logo}`}
                  alt={b.name}
                  loading="lazy"
                  class={`${b.logoClass ?? "logo-mark"} max-h-14 max-w-full w-auto object-contain opacity-90`}
                  onerror="this.style.display='none'; this.nextElementSibling?.classList.remove('hidden')"
                />
              )}
              <span
                class={`text-[13px] text-mute2 tracking-tightest ${b.logo ? "hidden" : ""}`}
              >
                {b.name}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
