---
/**
 * Floating dashboard mock for the hero.
 *
 * Renders a stylized LayerLogic control-panel UI as if it were a screenshot
 * floating over the hero — main card with a detection feed + chart, plus a
 * smaller secondary card peeking behind it for depth. Easy to replace with
 * a real product screenshot later: swap the markup inside `.hv-card` for
 * an <img> and keep the float/shadow wrapper.
 */
---

<div
  class="hero-visual relative w-full max-w-[560px] mx-auto"
  aria-hidden="true"
>
  {/* secondary card — peeks behind the main, off-axis */}
  <div class="hv-card hv-card--ghost">
    <div class="hv-row">
      <span class="hv-dot hv-dot--mute"></span>
      <span class="hv-mono">Line B · Standby</span>
      <span class="hv-mono hv-faint ml-auto">14:02</span>
    </div>
    <div class="hv-stat-row">
      <div>
        <div class="hv-label">Last reading</div>
        <div class="hv-stat-sm">NEGATIVE</div>
      </div>
      <div>
        <div class="hv-label">Sensor</div>
        <div class="hv-stat-sm">02 · idle</div>
      </div>
    </div>
  </div>

  {/* main card — the hero subject */}
  <div class="hv-card hv-card--main">
    <div class="hv-toolbar">
      <div class="hv-dots">
        <span></span><span></span><span></span>
      </div>
      <span class="hv-mono">LayerLogic Control · Line A</span>
      <span class="hv-mono hv-faint">v1.0</span>
    </div>

    <div class="hv-body">
      <div class="hv-side">
        <div class="hv-status">
          <span class="hv-dot hv-dot--live"></span>
          <span class="hv-mono">SENSOR_01 · live</span>
        </div>
        <div>
          <div class="hv-label">Runtime</div>
          <div class="hv-stat">06:42</div>
        </div>
        <div>
          <div class="hv-label">Target</div>
          <div class="hv-stat-sm hv-italic">L. monocytogenes</div>
        </div>
      </div>

      <div class="hv-chart">
        <div class="hv-chart-head">
          <span class="hv-label">Detection feed</span>
          <span class="hv-mono hv-faint">ΔI<sub>ds</sub></span>
        </div>
        <svg viewBox="0 0 200 100" class="hv-chart-svg">
          {/* grid */}
          <g stroke="currentColor" stroke-width="0.4" opacity="0.18">
            <line x1="0" y1="25" x2="200" y2="25"></line>
            <line x1="0" y1="50" x2="200" y2="50"></line>
            <line x1="0" y1="75" x2="200" y2="75"></line>
          </g>
          {/* baseline guide — marching ants */}
          <line
            class="hv-baseline"
            x1="0" y1="78" x2="200" y2="78"
            stroke="currentColor" opacity="0.3"
            stroke-dasharray="3 4" stroke-width="0.7"
          ></line>
          {/* scan line — sweeps across before the trace draws */}
          <line
            class="hv-scan"
            x1="0" y1="0" x2="0" y2="100"
            stroke="var(--color-accent2)"
            stroke-width="1"
            opacity="0.55"
          ></line>
          {/* the trace — drawn over time */}
          <polyline
            class="hv-trace"
            points="0,80 24,78 40,74 56,72 76,62 92,58 112,46 132,40 152,28 172,22 200,18"
            fill="none"
            stroke="var(--color-accent)"
            stroke-width="1.8"
            stroke-linejoin="round"
            stroke-linecap="round"
          ></polyline>
          {/* leading dot + pulsing halo when it arrives */}
          <circle
            class="hv-trace-halo"
            cx="200" cy="18" r="2.6"
            fill="none"
            stroke="var(--color-accent)"
            stroke-width="1.2"
          ></circle>
          <circle
            class="hv-trace-tip"
            cx="200" cy="18" r="2.6"
            fill="var(--color-accent)"
          ></circle>
        </svg>
      </div>
    </div>

    <div class="hv-verdict-row">
      <div class="hv-verdict-meta">
        <span class="hv-mono hv-faint">RESULT_01 · 14:08</span>
      </div>
      <div class="hv-verdict-badge">POSITIVE</div>
    </div>
  </div>
</div>

<style>
  .hero-visual {
    --hv-bg: #ffffff;
    --hv-border: color-mix(in srgb, var(--color-paper) 14%, transparent);
    --hv-shadow:
      0 18px 40px -18px color-mix(in srgb, var(--color-paper) 35%, transparent),
      0 6px 18px -8px color-mix(in srgb, var(--color-paper) 22%, transparent);
    padding: 0 8px;
  }
  /* Dark mode — card sits on the dark surface; use elevated ink tint */
  :global(body.dark) .hero-visual {
    --hv-bg: #1f1838;
    --hv-border: color-mix(in srgb, var(--color-paper) 18%, transparent);
    --hv-shadow:
      0 18px 50px -18px rgba(0, 0, 0, 0.55),
      0 6px 18px -8px rgba(0, 0, 0, 0.4);
  }

  .hv-card {
    position: relative;
    background: var(--hv-bg);
    border: 1px solid var(--hv-border);
    border-radius: 14px;
    box-shadow: var(--hv-shadow);
    color: var(--color-paper);
    font-family: var(--font-sans);
    font-feature-settings: "ss01", "cv11";
  }

  .hv-card--main {
    padding: 18px 18px 14px;
    transform: rotate(-1.5deg);
    animation: hv-float 9s ease-in-out infinite;
  }

  .hv-card--ghost {
    position: absolute;
    top: -22px;
    right: -18px;
    width: 56%;
    padding: 14px;
    transform: rotate(4deg);
    opacity: 0.9;
    z-index: 0;
    animation: hv-float-ghost 11s ease-in-out infinite;
  }

  .hv-card--main {
    position: relative;
    z-index: 1;
  }

  @keyframes hv-float {
    0%, 100% { transform: rotate(-1.5deg) translateY(0); }
    50%      { transform: rotate(-1.5deg) translateY(-6px); }
  }
  @keyframes hv-float-ghost {
    0%, 100% { transform: rotate(4deg) translateY(0); }
    50%      { transform: rotate(4deg) translateY(-3px); }
  }

  .hv-toolbar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--hv-border);
    font-size: 12px;
    color: color-mix(in srgb, var(--color-paper) 70%, transparent);
  }
  .hv-dots {
    display: inline-flex;
    gap: 5px;
  }
  .hv-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-paper) 18%, transparent);
  }
  .hv-faint {
    color: color-mix(in srgb, var(--color-paper) 45%, transparent);
    margin-left: auto;
  }
  .hv-mono {
    font-size: 11.5px;
    letter-spacing: 0.02em;
  }

  .hv-body {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 16px;
    padding: 16px 0 14px;
  }
  .hv-side {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .hv-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: color-mix(in srgb, var(--color-paper) 70%, transparent);
  }
  .hv-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11.5px;
    color: color-mix(in srgb, var(--color-paper) 80%, transparent);
  }
  .hv-stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 8px;
  }
  .hv-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--color-paper) 50%, transparent);
    margin-bottom: 4px;
  }
  .hv-stat {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .hv-stat-sm {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .hv-italic {
    font-style: italic;
  }

  .hv-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: none;
  }
  .hv-dot--live {
    background: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 22%, transparent);
    animation: hv-led 1.8s ease-in-out infinite;
  }
  .hv-dot--mute {
    background: color-mix(in srgb, var(--color-paper) 30%, transparent);
  }
  @keyframes hv-led {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.45; }
  }

  .hv-chart {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .hv-chart-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .hv-chart-svg {
    width: 100%;
    height: auto;
    color: var(--color-paper);
  }
  .hv-trace {
    stroke-dasharray: 320;
    stroke-dashoffset: 320;
    animation: hv-draw 4.5s cubic-bezier(0.4, 0.05, 0.3, 1) infinite;
  }
  .hv-trace-tip {
    opacity: 0;
    animation: hv-tip 4.5s linear infinite;
  }
  .hv-trace-halo {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: hv-halo 4.5s ease-out infinite;
  }
  @keyframes hv-draw {
    0% { stroke-dashoffset: 320; }
    65%, 95% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 320; }
  }
  @keyframes hv-tip {
    0%, 60% { opacity: 0; }
    70%, 92% { opacity: 1; }
    100% { opacity: 0; }
  }
  @keyframes hv-halo {
    0%, 60% { opacity: 0; transform: scale(1); }
    65%     { opacity: 0.9; transform: scale(1); }
    85%     { opacity: 0; transform: scale(3.6); }
    100%    { opacity: 0; transform: scale(3.6); }
  }

  /* baseline — marching ants */
  .hv-baseline {
    animation: hv-ants 6s linear infinite;
  }
  @keyframes hv-ants {
    to { stroke-dashoffset: -28; }
  }

  /* scan line — sweeps across the chart at the start of each cycle */
  .hv-scan {
    animation: hv-scan 4.5s ease-in-out infinite;
  }
  @keyframes hv-scan {
    0%   { transform: translateX(0); opacity: 0; }
    5%   { opacity: 0.6; }
    25%  { transform: translateX(200px); opacity: 0.6; }
    35%  { opacity: 0; }
    100% { transform: translateX(200px); opacity: 0; }
  }

  .hv-verdict-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--hv-border);
  }
  .hv-verdict-meta {
    font-size: 11px;
    color: color-mix(in srgb, var(--color-paper) 50%, transparent);
  }
  .hv-verdict-badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: #fff;
    background: var(--color-accent);
    border-radius: 999px;
    opacity: 0;
    transform-origin: center;
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 60%, transparent);
    animation: hv-verdict 4.5s cubic-bezier(0.34, 1.56, 0.64, 1) infinite;
  }
  @keyframes hv-verdict {
    0%, 68% {
      opacity: 0;
      transform: scale(0.7);
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 60%, transparent);
    }
    74% {
      opacity: 1;
      transform: scale(1.1);
      box-shadow: 0 0 0 10px color-mix(in srgb, var(--color-accent) 0%, transparent);
    }
    80%, 95% {
      opacity: 1;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(0.95);
    }
  }

  /* toolbar dots — staggered glow */
  .hv-dots span {
    animation: hv-dot-glow 5s ease-in-out infinite;
  }
  .hv-dots span:nth-child(1) { animation-delay: 0s; }
  .hv-dots span:nth-child(2) { animation-delay: 0.4s; }
  .hv-dots span:nth-child(3) { animation-delay: 0.8s; }
  @keyframes hv-dot-glow {
    0%, 60%, 100% { background: color-mix(in srgb, var(--color-paper) 18%, transparent); }
    65%, 75%      { background: color-mix(in srgb, var(--color-accent) 65%, transparent); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv-card--main,
    .hv-card--ghost,
    .hv-trace,
    .hv-trace-tip,
    .hv-trace-halo,
    .hv-baseline,
    .hv-scan,
    .hv-verdict-badge,
    .hv-dot--live,
    .hv-dots span {
      animation: none !important;
    }
    .hv-trace { stroke-dashoffset: 0; }
    .hv-trace-tip,
    .hv-verdict-badge { opacity: 1; }
    .hv-scan { opacity: 0; }
  }
</style>
