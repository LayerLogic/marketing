---
import { engineering, founders } from "~/lib/site";
import ScrollReveal from "~/components/react/ScrollReveal.tsx";

const base = import.meta.env.BASE_URL;
---

<section id="company" class="border-b border-line">
  <div class="max-w-[1320px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
    <div class="grid lg:grid-cols-12 gap-10 mb-14 lg:mb-20">
      <div class="lg:col-span-3">
        <div class="label mb-3">§ 06 — The team</div>
      </div>
      <div class="lg:col-span-9">
        <ScrollReveal client:load>
          <h2
            class="display-md text-[clamp(34px,5vw,68px)] font-medium max-w-[22ch] text-paper"
          >
            Engineers, microbiologists, graphene physicists.
          </h2>
        </ScrollReveal>
        <ScrollReveal client:load delay={120}>
          <p class="mt-6 text-paper/70 text-[17px] max-w-[60ch]">
            Six founders out of Chalmers — covering quantum device physics,
            systems biology, industrial engineering and operations — plus a
            small engineering team building the product.
          </p>
        </ScrollReveal>
      </div>
    </div>

    <div class="mb-16">
      <div
        class="flex items-baseline justify-between mb-6 border-b border-line pb-4"
      >
        <span class="label">Founders</span>
        <span class="font-mono text-[11px] text-mute">06</span>
      </div>
      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-x-6 gap-y-10"
      >
        {
          founders.map((f, i) => {
            const [local, domain] = f.email.split("@");
            return (
              <ScrollReveal client:load delay={i * 60}>
                <div>
                  <div
                    class="card-flip aspect-[3/4] mb-4 border border-line bg-ink2 relative overflow-hidden"
                    tabindex="0"
                  >
                    <img
                      src={`${base}${f.photo}`}
                      alt={f.name}
                      loading="lazy"
                      class="absolute inset-0 w-full h-full object-cover object-[center_top]"
                      style={(f as any).photoStyle ?? undefined}
                    />
                    <div class="card-flip__back card-flip__back--compact">
                      <div class="text-[10px] uppercase tracking-[.14em] text-mute2 mb-1.5">
                        Education
                      </div>
                      <div class="text-[13px] leading-snug font-medium">
                        {f.education}
                      </div>
                    </div>
                  </div>
                  <div class="text-[15px] font-medium tracking-tighter2 text-paper">
                    {f.name}
                  </div>
                  <div class="font-mono text-[11px] text-accent mt-1">
                    {f.role}
                  </div>
                  <a
                    href={`mailto:${f.email}`}
                    class="link-u inline-block mt-2 font-mono text-[10.5px] text-paper/80 hover:text-accent transition-colors break-words"
                    style="overflow-wrap:anywhere"
                  >
                    {local}@<wbr />{domain}
                  </a>
                </div>
              </ScrollReveal>
            );
          })
        }
      </div>
    </div>

    <div>
      <div
        class="flex items-baseline justify-between mb-6 border-b border-line pb-4"
      >
        <span class="label">Engineering</span>
        <span class="font-mono text-[11px] text-mute">
          {String(engineering.length).padStart(2, "0")}
        </span>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-x-6 gap-y-10">
        {
          engineering.map((e, i) => {
            const [local, domain] = e.email.split("@");
            return (
              <ScrollReveal client:load delay={i * 60}>
                <div>
                  <div
                    class="card-flip aspect-[3/4] mb-4 border border-line bg-ink2 relative overflow-hidden"
                    tabindex="0"
                  >
                    <img
                      src={`${base}${e.photo}`}
                      alt={e.name}
                      loading="lazy"
                      class="absolute inset-0 w-full h-full object-cover object-[center_top]"
                      style={(e as any).photoStyle ?? undefined}
                    />
                    <div class="card-flip__back card-flip__back--compact">
                      <div class="text-[10px] uppercase tracking-[.14em] text-mute2 mb-1.5">
                        Education
                      </div>
                      <div class="text-[13px] leading-snug font-medium">
                        {e.education}
                      </div>
                    </div>
                  </div>
                  <div class="text-[15px] font-medium tracking-tighter2 text-paper">
                    {e.name}
                  </div>
                  <div class="font-mono text-[11px] text-accent mt-1">
                    {e.role}
                  </div>
                  <a
                    href={`mailto:${e.email}`}
                    class="link-u inline-block mt-2 font-mono text-[10.5px] text-paper/80 hover:text-accent transition-colors break-words"
                    style="overflow-wrap:anywhere"
                  >
                    {local}@<wbr />{domain}
                  </a>
                </div>
              </ScrollReveal>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
