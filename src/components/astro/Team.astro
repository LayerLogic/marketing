---
import { engineering, founders, research } from "~/lib/site";
import ScrollReveal from "~/components/react/ScrollReveal.tsx";

const stripe = (angle: number) =>
  `repeating-linear-gradient(${angle}deg, #15151a 0 10px, #101012 10px 20px)`;
---

<section id="company" class="border-b border-line">
  <div class="max-w-[1320px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
    <div class="grid lg:grid-cols-12 gap-10 mb-14 lg:mb-20">
      <div class="lg:col-span-3">
        <div class="label mb-3">§ 05 — The team</div>
      </div>
      <div class="lg:col-span-9">
        <ScrollReveal client:load>
          <h2
            class="display-md text-[clamp(34px,5vw,68px)] font-medium max-w-[22ch] text-paper"
          >
            Engineers, microbiologists, graphene physicists.
          </h2>
        </ScrollReveal>
        <ScrollReveal client:load delay={120}>
          <p class="mt-6 text-paper/70 text-[17px] max-w-[60ch]">
            Six founders and a small core team — built around three decades of
            graphene research at Chalmers and a deep bench in food-safety
            microbiology.
          </p>
        </ScrollReveal>
      </div>
    </div>

    <div class="mb-16">
      <div
        class="flex items-baseline justify-between mb-6 border-b border-line pb-4"
      >
        <span class="label">Founders</span>
        <span class="font-mono text-[11px] text-mute">06</span>
      </div>
      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-x-6 gap-y-10"
      >
        {
          founders.map((f, i) => (
            <ScrollReveal client:load delay={i * 60}>
              <div>
                <div class="aspect-[3/4] mb-4 border border-line bg-ink2 relative overflow-hidden">
                  <div
                    class="absolute inset-0"
                    style={`background-image:${stripe(f.angle)}`}
                  />
                  <span class="absolute bottom-2 left-2 font-mono text-[9px] text-mute2">
                    [portrait]
                  </span>
                </div>
                <div class="text-[15px] font-medium tracking-tighter2 text-paper">
                  {f.name}
                </div>
                <div class="font-mono text-[11px] text-accent mt-1">
                  {f.role}
                </div>
                <div class="text-[12px] text-mute2 mt-1 leading-snug">
                  {f.affil}
                </div>
              </div>
            </ScrollReveal>
          ))
        }
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-10">
      <div>
        <div
          class="flex items-baseline justify-between mb-6 border-b border-line pb-4"
        >
          <span class="label">Research</span>
          <span class="font-mono text-[11px] text-mute">02</span>
        </div>
        <div class="grid grid-cols-2 gap-6">
          {
            research.map((r) => (
              <div>
                <div class="aspect-[3/4] mb-3 border border-line bg-ink2 relative overflow-hidden">
                  <div
                    class="absolute inset-0"
                    style={`background-image:${stripe(r.angle)}`}
                  />
                </div>
                <div class="text-[14px] font-medium tracking-tighter2 text-paper">
                  {r.name}
                </div>
                <div class="text-[12px] text-mute2 mt-1">{r.affil}</div>
              </div>
            ))
          }
        </div>
      </div>
      <div>
        <div
          class="flex items-baseline justify-between mb-6 border-b border-line pb-4"
        >
          <span class="label">Engineering</span>
          <span class="font-mono text-[11px] text-mute">02</span>
        </div>
        <div class="grid grid-cols-2 gap-6">
          {
            engineering.map((e) => (
              <div>
                <div class="aspect-[3/4] mb-3 border border-line bg-ink2 relative overflow-hidden">
                  <div
                    class="absolute inset-0"
                    style={`background-image:${stripe(e.angle)}`}
                  />
                </div>
                <div class="text-[14px] font-medium tracking-tighter2 text-paper">
                  {e.name}
                </div>
                <div class="text-[12px] text-mute2 mt-1">{e.affil}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
