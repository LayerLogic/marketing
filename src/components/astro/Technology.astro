---
import ScrollReveal from "~/components/react/ScrollReveal.tsx";
---

<section id="technology" class="border-b border-line">
  <div class="max-w-[1320px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
    <div class="grid lg:grid-cols-12 gap-10 mb-16 lg:mb-20">
      <div class="lg:col-span-3">
        <div class="label mb-3">§ 03 — The technology behind it</div>
      </div>
      <div class="lg:col-span-9">
        <ScrollReveal client:load>
          <h2
            class="display-md text-[clamp(34px,5vw,68px)] font-medium max-w-[22ch] text-paper"
          >
            Underneath: a graphene field-effect transistor.
          </h2>
        </ScrollReveal>
        <ScrollReveal client:load delay={120}>
          <p class="mt-6 text-paper/75 text-[17px] max-w-[60ch]">
            A graphene field-effect transistor (gFET) is a charge sensor. We
            add receptors that grab the target; when something binds, the
            signal changes. No amplification, no thermal cycling, no
            reagents. We target
            <em class="not-italic text-paper">Listeria monocytogenes</em>
            today, but the same chip can be tuned for other bacteria,
            viruses, and analytes.
          </p>
        </ScrollReveal>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 border-t border-line">
      {/* STEP 01 */}
      <article class="border-line md:border-r p-8 lg:p-10 group">
        <div class="flex items-center justify-between mb-8">
          <span class="label !text-[12px] text-accent">Step 01 — Capture</span>
          <span class="text-[11px] text-mute tracking-[.08em]">t = 0s</span>
        </div>
        <svg
          viewBox="0 0 280 140"
          class="w-full h-auto mb-8"
          aria-label="Functionalized graphene surface with receptor molecules"
        >
          <rect
            x="0"
            y="110"
            width="280"
            height="20"
            fill="#101012"
            stroke="#1F1F22"></rect>
          <line x1="0" y1="100" x2="280" y2="100" stroke="#06B6A7"
            stroke-width="1.4"></line>
          <g stroke="#1F1F22" fill="none" stroke-width="0.8">
            <polygon points="20,100 30,95 40,100 40,108 30,113 20,108"
            ></polygon>
            <polygon points="60,100 70,95 80,100 80,108 70,113 60,108"
            ></polygon>
            <polygon points="100,100 110,95 120,100 120,108 110,113 100,108"
            ></polygon>
            <polygon points="140,100 150,95 160,100 160,108 150,113 140,108"
            ></polygon>
            <polygon points="180,100 190,95 200,100 200,108 190,113 180,108"
            ></polygon>
            <polygon points="220,100 230,95 240,100 240,108 230,113 220,108"
            ></polygon>
          </g>
          <g stroke="#EDEDE8" stroke-width="1.2" fill="none">
            <path d="M40 100 L40 80 M40 80 L34 70 M40 80 L46 70"></path>
            <path d="M100 100 L100 80 M100 80 L94 70 M100 80 L106 70"></path>
            <path d="M160 100 L160 80 M160 80 L154 70 M160 80 L166 70"></path>
            <path d="M220 100 L220 80 M220 80 L214 70 M220 80 L226 70"></path>
          </g>
          <g fill="#06B6A7">
            <circle class="analyte-1" cx="40" cy="40" r="4"></circle>
            <circle class="analyte-2" cx="160" cy="32" r="4"></circle>
          </g>
          <g
            stroke="#06B6A7"
            stroke-width="0.8"
            stroke-dasharray="2 3"
            fill="none"
          >
            <path class="trail-anim" d="M40 44 L40 60"></path>
            <path class="trail-anim-2" d="M160 36 L160 60"></path>
          </g>
          <text x="0" y="135" font-family="JetBrains Mono" font-size="9"
            fill="#6B6B72">SiO₂ / Si gate</text
          >
          <text x="245" y="98" font-family="JetBrains Mono" font-size="9"
            fill="#06B6A7">graphene</text
          >
        </svg>
        <h3 class="text-[20px] font-medium mb-2 tracking-tighter2 text-paper">
          Capture.
        </h3>
        <p class="text-paper/75 text-[15px] leading-relaxed">
          Receptors on the graphene surface grab the target out of the sample
          — bacteria, viruses, spores, or smaller molecules.
        </p>
      </article>

      {/* STEP 02 */}
      <article
        class="border-line md:border-r p-8 lg:p-10 border-t md:border-t-0 group"
      >
        <div class="flex items-center justify-between mb-8">
          <span class="label !text-[12px] text-accent">Step 02 — Transduce</span>
          <span class="text-[11px] text-mute tracking-[.08em]">t ≈ 02:00</span>
        </div>
        <svg
          viewBox="0 0 280 140"
          class="w-full h-auto mb-8"
          aria-label="Binding event shifts the gFET channel field"
        >
          <rect
            x="0"
            y="110"
            width="280"
            height="20"
            fill="#101012"
            stroke="#1F1F22"></rect>
          <rect
            x="20"
            y="80"
            width="40"
            height="20"
            fill="#2A2A2E"
            stroke="#EDEDE8"
            stroke-width="0.8"></rect>
          <rect
            x="220"
            y="80"
            width="40"
            height="20"
            fill="#2A2A2E"
            stroke="#EDEDE8"
            stroke-width="0.8"></rect>
          <text
            x="40"
            y="74"
            font-family="JetBrains Mono"
            font-size="9"
            fill="#9A9AA1"
            text-anchor="middle">S</text
          >
          <text
            x="240"
            y="74"
            font-family="JetBrains Mono"
            font-size="9"
            fill="#9A9AA1"
            text-anchor="middle">D</text
          >
          <line x1="60" y1="92" x2="220" y2="92" stroke="#06B6A7"
            stroke-width="1.6"></line>
          <circle cx="140" cy="80" r="5" fill="#06B6A7"></circle>
          <path d="M140 92 L140 85" stroke="#06B6A7" stroke-width="1"></path>
          <g stroke="#06B6A7" fill="none" stroke-width="0.7" opacity=".7">
            <path d="M140 80 Q120 60 100 50"></path>
            <path d="M140 80 Q160 60 180 50"></path>
            <path d="M140 80 Q110 70 90 75"></path>
            <path d="M140 80 Q170 70 190 75"></path>
          </g>
          <text x="36" y="40" font-family="JetBrains Mono" font-size="11"
            fill="#EDEDE8">ΔV_g</text
          >
          <text x="36" y="54" font-family="JetBrains Mono" font-size="11"
            fill="#06B6A7">+0.014 V</text
          >
          <rect
            x="-20"
            y="80"
            width="2"
            height="20"
            fill="#06B6A7"
            opacity=".9"
            class="scan-line"></rect>
        </svg>
        <h3 class="text-[20px] font-medium mb-2 tracking-tighter2 text-paper">
          Transduce.
        </h3>
        <p class="text-paper/75 text-[15px] leading-relaxed">
          When something binds, the electric field across the channel shifts.
          The chip reads it straight away as a change in current.
        </p>
      </article>

      {/* STEP 03 */}
      <article class="p-8 lg:p-10 border-t md:border-t-0 border-line group">
        <div class="flex items-center justify-between mb-8">
          <span class="label !text-[12px] text-accent">Step 03 — Read</span>
          <span class="text-[11px] text-mute tracking-[.08em]">t &lt; 15:00</span>
        </div>
        <svg
          viewBox="0 0 280 140"
          class="w-full h-auto mb-8"
          aria-label="Digital readout under fifteen minutes"
        >
          <rect
            x="20"
            y="20"
            width="240"
            height="100"
            rx="6"
            fill="#101012"
            stroke="#1F1F22"></rect>
          <polyline
            class="wave-anim"
            points="34,90 60,90 70,72 90,78 110,52 130,60 150,40 170,46 190,30 210,34 230,28 246,30"
            stroke="#06B6A7"
            stroke-width="1.6"
            fill="none"
            stroke-linejoin="round"></polyline>
          <circle class="wave-tip" cx="34" cy="90" r="2.6" fill="#06B6A7"
          ></circle>
          <line x1="34" y1="90" x2="246" y2="90" stroke="#1F1F22"
            stroke-dasharray="2 3"></line>
          <text x="34" y="38" font-family="JetBrains Mono" font-size="10"
            fill="#9A9AA1">DETECT_01</text
          >
          <text x="34" y="112" font-family="JetBrains Mono" font-size="9"
            fill="#6B6B72">L. monocytogenes · 14:08</text
          >
          <text
            class="pos-blink"
            x="246"
            y="112"
            font-family="JetBrains Mono"
            font-size="10"
            fill="#06B6A7"
            text-anchor="end">POSITIVE</text
          >
        </svg>
        <h3 class="text-[20px] font-medium mb-2 tracking-tighter2 text-paper">
          Read.
        </h3>
        <p class="text-paper/75 text-[15px] leading-relaxed">
          The device turns that signal into a clear pass or fail, in under
          fifteen minutes from sample.
        </p>
      </article>
    </div>
  </div>
</section>
