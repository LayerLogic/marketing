---
interface Props {
  size?: number;
}
const { size = 40 } = Astro.props;

const base = import.meta.env.BASE_URL;
const light = `${base}assets/logos/svg/Symbol color.svg`;
const dark = `${base}assets/logos/svg/Symbol white with purple detail.svg`;
---

<span
  class="ll-logo"
  style={`--ll-size:${size}px;`}
  aria-hidden="true"
>
  <img class="ll-logo-img ll-logo-light" src={light} alt="" />
  <img class="ll-logo-img ll-logo-dark" src={dark} alt="" />
</span>

<style is:global>
  .ll-logo {
    position: relative;
    display: inline-block;
    width: var(--ll-size, 40px);
    height: var(--ll-size, 40px);
    flex: none;
    vertical-align: middle;
  }
  .ll-logo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .ll-logo-dark {
    opacity: 0;
  }
  body.dark .ll-logo-light {
    opacity: 0;
  }
  body.dark .ll-logo-dark {
    opacity: 1;
  }
</style>
