---
import StatCounter from "~/components/react/StatCounter.tsx";
import ScrollReveal from "~/components/react/ScrollReveal.tsx";
---

<section class="border-b border-line">
  <div class="max-w-[1320px] mx-auto px-6 lg:px-10 py-24 lg:py-36">
    <div class="flex items-baseline justify-between mb-14 lg:mb-20">
      <div class="label">§ 01 — The shift</div>
      <div class="label hidden md:block">vs. lab-based methods</div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-y-16">
      <ScrollReveal client:load className="lg:pr-10 lg:border-r lg:border-line">
        <div class="label mb-4">Time to result</div>
        <div
          class="font-mono stat-num text-[clamp(40px,4.5vw,64px)] font-medium num-tabular text-paper"
        >
          <span class="lt">&lt;</span><StatCounter client:visible target={15} /><span
            class="text-accent">min</span
          >
        </div>
        <p
          class="mt-6 text-paper/80 text-[16px] leading-relaxed max-w-[34ch]"
        >
          Sample to readout in under fifteen minutes — at the point of
          production, by an operator. Not a lab technician.
        </p>
      </ScrollReveal>

      <ScrollReveal
        client:load
        delay={120}
        className="lg:px-10 lg:border-r lg:border-line"
      >
        <div class="label mb-4">Sensitivity</div>
        <div
          class="font-mono stat-num text-[clamp(40px,4.5vw,64px)] font-medium text-paper whitespace-nowrap"
        >
          PCR<span class="text-accent">-grade</span>
        </div>
        <p
          class="mt-6 text-paper/80 text-[16px] leading-relaxed max-w-[34ch]"
        >
          Limit of detection rivalling polymerase chain reaction — without the
          thermal cycling, reagents or two-day round-trip.
        </p>
      </ScrollReveal>

      <ScrollReveal client:load delay={240} className="lg:pl-10">
        <div class="label mb-4">Avg. cost prevented per event</div>
        <div
          class="font-mono stat-num text-[clamp(40px,4.5vw,64px)] font-medium num-tabular text-paper"
        >
          €<StatCounter client:visible target={200} /><span
            class="text-accent">K</span
          >
        </div>
        <p
          class="mt-6 text-paper/80 text-[16px] leading-relaxed max-w-[34ch]"
        >
          A single contamination event — recall, line shutdown, brand damage
          — can cost a producer up to €200,000. Catch it before it ships.
        </p>
      </ScrollReveal>
    </div>

    <ScrollReveal client:load delay={120}>
      <p
        class="mt-20 lg:mt-28 max-w-[58ch] text-[18px] lg:text-[20px] text-paper/75 leading-[1.55]"
      >
        Traditional microbial testing means shipping samples to a lab and
        waiting two to four days for plate culture or PCR results. By the time
        the answer arrives, the product has often shipped. <span
          class="text-paper">We move detection in-process</span
        > — making contamination a problem you catch, not a problem you discover.
      </p>
    </ScrollReveal>
  </div>
</section>
